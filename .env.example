# Database
# Für lokale Entwicklung: In .env.local setzen
# Für Production: In Vercel als Environment Variable setzen
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: Getrennte Produktions-DB für Migrationen (./scripts/migrate-production.sh)
# DATABASE_URL_PRODUCTION="postgresql://...@db.<project-ref>.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL_PRODUCTION="postgresql://...@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# Supabase + Vercel (bei MaxClientsInSessionMode-Fehler):
# DATABASE_URL MUSS Port 6543 (Transaction-Modus) nutzen, NICHT 5432 (Session-Modus)
# DATABASE_URL = postgresql://...@db.XXX.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL   = postgresql://...@db.XXX.supabase.co:5432/postgres (für Migrations)

# NextAuth.js / Auth.js
AUTH_SECRET="your-secret-key-here"
# AUTH_URL muss exakt der URL entsprechen, unter der die App läuft (z. B. Browser-Tab), sonst: ClientFetchError / HTML statt JSON
AUTH_URL="http://localhost:3000"

# E-Mail-Konfiguration (SMTP)
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password

# Stripe (Abrechnung / Zahlungsarten)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
