{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dpp-saas.example.com/schemas/OBJ-039-notification.json",
  "title": "Notification",
  "description": "OBJ-039: Notification – In-App-Benachrichtigungen",
  "type": "object",
  "required": ["id", "userId", "type", "read"],
  "properties": {
    "id": { "type": "string", "description": "CUID" },
    "userId": { "type": "string" },
    "type": { "type": "string", "description": "Event key from NOTIFICATION_EVENT_KEYS" },
    "referenceType": { "type": ["string", "null"] },
    "referenceId": { "type": ["string", "null"] },
    "read": { "type": "boolean", "default": false },
    "readAt": { "type": ["string", "null"], "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "message": { "type": ["string", "null"] },
    "targetRoute": { "type": ["string", "null"] },
    "targetEntityId": { "type": ["string", "null"] },
    "targetTab": { "type": ["string", "null"] },
    "organisationId": { "type": ["string", "null"] },
    "actorRole": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
