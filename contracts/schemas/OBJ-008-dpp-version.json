{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dpp-saas.example.com/schemas/OBJ-008-dpp-version.json",
  "title": "DppVersion",
  "description": "OBJ-008: DPP Version – Publizierte Versionen",
  "type": "object",
  "required": ["id", "dppId", "version", "name", "category", "createdByUserId"],
  "properties": {
    "id": { "type": "string", "description": "CUID" },
    "dppId": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "name": { "type": "string" },
    "description": { "type": ["string", "null"] },
    "category": { "type": "string" },
    "sku": { "type": ["string", "null"] },
    "gtin": { "type": ["string", "null"] },
    "brand": { "type": ["string", "null"] },
    "countryOfOrigin": { "type": ["string", "null"] },
    "materials": { "type": ["string", "null"] },
    "materialSource": { "type": ["string", "null"] },
    "careInstructions": { "type": ["string", "null"] },
    "isRepairable": { "type": ["string", "null"] },
    "sparePartsAvailable": { "type": ["string", "null"] },
    "lifespan": { "type": ["string", "null"] },
    "conformityDeclaration": { "type": ["string", "null"] },
    "disposalInfo": { "type": ["string", "null"] },
    "takebackOffered": { "type": ["string", "null"] },
    "takebackContact": { "type": ["string", "null"] },
    "secondLifeInfo": { "type": ["string", "null"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "createdByUserId": { "type": "string" },
    "publicUrl": { "type": ["string", "null"], "format": "uri" },
    "qrCodeImageUrl": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
