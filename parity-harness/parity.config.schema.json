{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ParityConfig",
  "type": "object",
  "properties": {
    "altBaseUrl": { "type": "string", "format": "uri" },
    "newBaseUrl": { "type": "string", "format": "uri" },
    "timeoutMs": { "type": "integer", "minimum": 1000 },
    "toleratedFields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "toleratedPathPatterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "normalizeConfigPath": { "type": "string", "description": "Path to normalize.json" }
  },
  "required": ["altBaseUrl", "newBaseUrl"]
}
